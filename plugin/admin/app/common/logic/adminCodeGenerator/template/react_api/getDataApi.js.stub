// 生成控制器的其它方法
if (isset($data['controller_admin']['other_functions']) && is_array($data['controller_admin']['other_functions'])) {
    
    foreach ($data['controller_admin']['other_functions'] as $key => $value) {
        $apiList[] = [
            'title' => $value['title'],
            'functoin_name' => $value['name'],
            'method' => $value['method'],
            'url' => "{$apiPrefix}/admin/{$tableNameToCamelCase}/{$value['name']}"           
