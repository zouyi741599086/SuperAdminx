<?php
    // getList方法
    if (in_array('getList', $serviceFunction)) {
    echo "
    /**
     * 列表
     * @param array \$params get参数
     * @param array \$with 关联
     * @param array \$withCount 关联统计
     * @param bool \$page 是否分页
     * */
    public function getList(array \$params = [], array \$with = [], array \$withCount = [], bool \$page = true)
    {
        return \$this->{$tableNameToCamelCaseLower}QueryLogic->getList(\$params, \$with, \$withCount, \$page);
    }\n";
    }
?>